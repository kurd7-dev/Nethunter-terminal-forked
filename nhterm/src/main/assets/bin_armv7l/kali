#!/data/data/com.offsec.nhterm/files/usr/bin_armv7l/bash
# Version: 1.0.8

MODE="${1:-session}"

if [ "$MODE" = "--auth-check" ]; then
  TARGET_USER="${KALI_VERIFY_USER:-root}"
else
  TARGET_USER="${1:-root}"
fi

case "$TARGET_USER" in
  ""|*[!A-Za-z0-9._-]*)
    TARGET_USER="root"
    ;;
esac

# export path for android bins/tools
export PATH=/data/data/com.offsec.nhterm/files/home/.nhterm/script:/data/data/com.offsec.nhterm/files/usr/bin_armv7l:/data/data/com.offsec.nhterm/files/usr/sbin:/sbin:/system/bin:/system/xbin:/system_ext/bin:/apex/com.android.runtime/bin:/apex/com.android.art/bin:/odm/bin:/vendor/bin:/product/bin:.

##
# `magisk -V` works without root and returns an integer, e.g. 28100.
##
MAGISK_VERSION_RAW="$(magisk -V 2>/dev/null || true)"

if echo "$MAGISK_VERSION_RAW" | grep -qE '^[0-9]+$'; then
  MAGISK_VERSION="$MAGISK_VERSION_RAW"
else
  MAGISK_VERSION="0"
fi

##
# Find and identify su solution
# As different solutions have and use different args :(
##

SU1=$(which su 2>/dev/null)
if [ -z "$SU1" ]; then
  echo "[android-su][ERROR] 'su' binary not found in PATH" >&2
  exit 1
fi

SU_FLAVOR="unknown"

# try obvious flags first
for f in --version -v -V --help; do
  o="$("$SU1" $f 2>/dev/null || true)"
  case "$o" in
    *MagiskSU* )
      SU_FLAVOR="MagiskSU"
      # Use different CLI forms depending on Magisk version
      # - For version code 28100 (Magisk 28.1) we must use: su -mm -s "$@"
      # - For versions above 28100 we must use: su -i -mm -s "$*"
      if [ "$MAGISK_VERSION" -eq 28100 ]; then
        SU2="$SU1 -mm -c"
      elif [ "$MAGISK_VERSION" -gt 28100 ]; then
        SU2="$SU1 -i -mm -c"
      else
        # Magisk older than 28.1 or magisk not installed; fall back to legacy behavior
        SU2="$SU1 -mm -c"
      fi
      ;;
    *SuperSU*|*superuser*|*Chainfire* )
      SU_FLAVOR="SuperSU"
      SU2="$SU1 -c"
      ;;
    *busybox* )
      SU_FLAVOR="busybox su"
      SU2="$SU1 -c"
      ;;
    *toybox* )
      SU_FLAVOR="toybox su"
      SU2="$SU1 -c"
      ;;
    *KernelSU* )
      SU_FLAVOR="KernelSU"
      SU2="$SU1 -M -p -c"
      ;;
  esac
  [ -n "$SU_FLAVOR" ] && [ "$SU_FLAVOR" != "unknown" ] && break

done

if [ -z "${SU2+x}" ]; then
  # Fallback if we couldn't detect variant
  SU2="$SU1 -c"
fi

##
# Finally do the main script job
##

# clear out old view
#clear

# unset things and readd chroot things
unset PATH
unset TMP
unset TMPDIR
unset HOME
unset LD_PRELOAD
unset LD_LIBRARY_PATH

## Combine android $PATH to kali chroot $PATH
export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
export TERM=xterm-256color
export LANG=en_US.UTF-8
export HOME=/root
export TMP=/tmp
export TMPDIR=/tmp
export USER=$TARGET_USER
export MAIL=/var/mail/$TARGET_USER
export LOGNAME=$TARGET_USER
export SHLVL=1
# Lets pass a binky export here too ;)
export YOU_KNOW_WHAT=THIS_IS_KALI_LINUX_NETHUNTER_FROM_JAVA_BINKY

if [ "$TARGET_USER" = "root" ]; then
  CHROOT_CMD="/system/bin/chroot /data/local/nhsystem/kalifs /bin/su"
else
  CHROOT_CMD="/system/bin/chroot /data/local/nhsystem/kalifs /bin/su - $TARGET_USER"
fi

if [ "$MODE" = "--auth-check" ]; then
  CHROOT_CMD="/system/bin/chroot /data/local/nhsystem/kalifs /usr/bin/python3 -c \"import base64,crypt,spwd,sys;u=base64.b64decode('$KALI_VERIFY_USER_B64').decode();p=base64.b64decode('$KALI_VERIFY_PASSWORD_B64').decode();e=spwd.getspnam(u).sp_pwdp;sys.exit(0 if e and e not in ('!', '*', 'x') and crypt.crypt(p, e)==e else 1)\""
fi

$SU2 "$CHROOT_CMD"
